{
  "exclude": ["../model/", "../vault/", "../datastore"],
  "tasks": {
    "check": "deno check main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "fetch-schema:hetzner": "deno run --allow-read --allow-write --allow-env --allow-net main.ts fetch-schema --provider hetzner",
    "fetch-schema:digitalocean": "deno run --allow-read --allow-write --allow-env --allow-net main.ts fetch-schema --provider digitalocean",
    "generate:hetzner": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run=deno main.ts generate-models --provider hetzner",
    "generate:digitalocean": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run=deno main.ts generate-models --provider digitalocean"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.8",
    "@apidevtools/json-schema-ref-parser": "npm:@apidevtools/json-schema-ref-parser@11",
    "@std/path": "jsr:@std/path@^1",
    "pluralize": "npm:pluralize@8"
  }
}
